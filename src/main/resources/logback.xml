<configuration>

    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>
    <conversionRule conversionWord="highlight" class="com.nami.logback.HighlightCompositeConverter"/>

    <root level="DEBUG">
        <appender-ref ref="LIB_CONSOLE"/>
    </root>
    <appender name="LIB_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%highlight(%d{HH:mm:ss} %msg%n)</pattern>
        </encoder>
    </appender>

    <logger name="com.nami" level="DEBUG" additivity="false">
        <appender-ref ref="APP_CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    <appender name="APP_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%highlight(%d{HH:mm:ss} [%logger] %msg%n)</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>/data/log.txt</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%logger] %msg%n</pattern>
        </encoder>
    </appender>

</configuration>